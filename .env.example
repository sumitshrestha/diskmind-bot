# DiskMind sample environment configuration
# Copy this file to .env and adjust as needed.

# LLM provider: ollama (default) or openai
DISKMIND_LLM_PROVIDER=ollama

# Ollama settings
DISKMIND_OLLAMA_MODEL=llama3.1:8b
# OLLAMA_HOST=http://localhost:11434

# OpenAI settings (only used if DISKMIND_LLM_PROVIDER=openai)
# OPENAI_API_KEY=your_openai_api_key_here
# DISKMIND_OPENAI_MODEL=gpt-4o-mini

# Scan behavior
DISKMIND_MAX_ITERATIONS=10
DISKMIND_ROOT_DEPTH=1
DISKMIND_DIVE_DEPTH=2
DISKMIND_TOP_FILES_LIMIT=50

# Optional manual root override (Windows example, semicolon-separated)
# If not set, DiskMind uses default drive candidates and prompts for selection.
# DISKMIND_ROOTS=C:\\;D:\\;E:\\
